# Environment Variables Example for OasisNotes Employee Website
# Copy this file to .env and configure the values for local development.

# Base API URL for backend services
REACT_APP_BASE_URL=https://api.example.com/api/v1/

# WebSocket URL for real-time notifications and chat
REACT_APP_SOCKET_URL=https://api.example.com/

# CloudFront CDN Base URL for static assets and uploads
REACT_APP_CLOUDFRONT_URL=https://cloudfront.net/

# Disable source maps in production builds to prevent source code exposure
GENERATE_SOURCEMAP=false
